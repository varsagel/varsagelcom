generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String        @id @default(uuid())
  email           String        @unique
  password        String
  name            String
  profileImage    String?
  phone           String?
  location        String?
  isBanned        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  rating          Float         @default(0)
  reviewCount     Int           @default(0)
  adminLogs       AdminLog[]    @relation("AdminLogs")
  answersGiven    Answer[]      @relation("AnswersGiven")
  favorites       Favorite[]
  listings        Listing[]
  listingViews    ListingView[]
  messages        Message[]
  offers          Offer[]
  questionsAsked  Question[]    @relation("QuestionsAsked")
  reportsCreated  Report[]      @relation("ReportsCreated")
  reportsResolved Report[]      @relation("ReportsResolved")
  reviewsGiven    Review[]      @relation("ReviewsGiven")
  reviews         Review[]      @relation("ReviewsReceived")
}

model Listing {
  id                   String         @id @default(uuid())
  displayNumber        String         @unique
  title                String
  description          String
  category             String
  subcategory          String?
  location             String
  district             String?
  budgetMin            Float
  budgetMax            Float
  price                Float?
  isFeatured           Boolean        @default(false)
  featuredUntil        DateTime?
  images               String
  videoUrl             String?
  expiresAt            DateTime
  status               String         @default("active")
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  likeCount            Int            @default(0)
  favoriteCount        Int            @default(0)
  viewCount            Int            @default(0)
  categorySpecificData Json?
  mileageMin           Int?
  mileageMax           Int?
  icon                 String?
  userId               String
  conversations        Conversation[]
  favorites            Favorite[]
  user                 User           @relation(fields: [userId], references: [id])
  views                ListingView[]
  offers               Offer[]
  questions            Question[]
  reviews              Review[]
}

model Offer {
  id                   String        @id @default(uuid())
  displayNumber        String        @unique
  userId               String
  listingId            String
  price                Float
  duration             String
  message              String
  experience           String        @default("")
  portfolio            String        @default("")
  guaranteeOffered     Boolean       @default(false)
  revisionCount        Int           @default(0)
  additionalServices   Json          @default("[]")
  status               String        @default("pending")
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  categorySpecificData Json?
  conversation         Conversation?
  listing              Listing       @relation(fields: [listingId], references: [id])
  user                 User          @relation(fields: [userId], references: [id])
}

model Favorite {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
}

model Review {
  id         String   @id @default(uuid())
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
  reviewerId String
  userId     String
  listingId  String?
  listing    Listing? @relation(fields: [listingId], references: [id])
  reviewer   User     @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  user       User     @relation("ReviewsReceived", fields: [userId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  type      String
  title     String?
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  relatedId String?
  userId    String
  metadata  Json?
}

model Conversation {
  id        String    @id @default(uuid())
  offerId   String    @unique
  listingId String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  listing   Listing?  @relation(fields: [listingId], references: [id])
  offer     Offer     @relation(fields: [offerId], references: [id])
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  content        String
  senderId       String
  conversationId String
  createdAt      DateTime     @default(now())
  isRead         Boolean      @default(false)
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  sender         User         @relation(fields: [senderId], references: [id])
}

model Question {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  listingId String
  askerId   String
  answer    Answer?
  asker     User     @relation("QuestionsAsked", fields: [askerId], references: [id])
  listing   Listing  @relation(fields: [listingId], references: [id])
}

model Answer {
  id          String   @id @default(uuid())
  content     String
  createdAt   DateTime @default(now())
  questionId  String   @unique
  responderId String
  question    Question @relation(fields: [questionId], references: [id])
  responder   User     @relation("AnswersGiven", fields: [responderId], references: [id])
}

model ListingView {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  ipAddress String?
  userId    String?
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id])
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([userId, listingId])
}

model Report {
  id             String    @id @default(uuid())
  targetType     String
  targetId       String
  reason         String
  status         String    @default("PENDING")
  priority       String    @default("NORMAL")
  moderatorNotes String?
  createdAt      DateTime  @default(now())
  resolvedAt     DateTime?
  reportedById   String
  resolvedById   String?
  reportedBy     User      @relation("ReportsCreated", fields: [reportedById], references: [id])
  resolvedBy     User?     @relation("ReportsResolved", fields: [resolvedById], references: [id])
}

model AdminLog {
  id         String   @id @default(uuid())
  action     String
  targetType String
  targetId   String
  details    Json?
  createdAt  DateTime @default(now())
  adminId    String
  admin      User     @relation("AdminLogs", fields: [adminId], references: [id])
}
